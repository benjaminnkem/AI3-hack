# Mesh runtime configuration is app-specific.
#
# Copy the relevant files instead of putting shared secrets at the repository root:
#   apps/api/.env.example          -> apps/api/.env
#   apps/web/.env.example          -> apps/web/.env.local
#   apps/contracts/.env.example    -> apps/contracts/.env
#   apps/telegram-bot/.env.example -> apps/telegram-bot/.env
#
# Never commit populated environment files or real credentials.
