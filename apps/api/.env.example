# Runtime. NODE_ENV, PORT, API_PREFIX and WEB_ORIGINS are not secrets.
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
WEB_ORIGINS=http://localhost:3000
# Required secret in deployment. Local default matches root docker-compose.yml.
DATABASE_URL=postgresql://mesh:mesh@localhost:5432/mesh

# Required secret: create at https://gonkarouter.io dashboard. Models/base URL are exact live Gonka values.
GONKA_BASE_URL=https://api.gonkarouter.io
GONKA_API_KEY=
GONKA_KIMI_MODEL=moonshotai/Kimi-K2.6
# If your Gonka channel temporarily rejects Kimi, retry Kimi-designated calls with this exact model.
GONKA_KIMI_FALLBACK_MODEL=MiniMaxAI/MiniMax-M2.7
GONKA_MINIMAX_MODEL=MiniMaxAI/MiniMax-M2.7
GONKA_MAX_TOKENS=4096
GONKA_VISUAL_MAX_TOKENS=1536
GONKA_CLAIM_MAX_TOKENS=1536
GONKA_INVESTIGATOR_MAX_TOKENS=3072
GONKA_ADVERSARIAL_MAX_TOKENS=2048
GONKA_NARRATIVE_MAX_TOKENS=1536
GONKA_TIMEOUT_MS=120000
GONKA_MAX_RETRIES=1
GONKA_RETRY_BASE_MS=2000

# Required secret: create at https://app.tavily.com. Remaining values are safe defaults.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=fast
TAVILY_EXTRACT_DEPTH=basic
TAVILY_MAX_RESULTS_PER_CLAIM=4
TAVILY_MAX_QUERIES_PER_CLAIM=2
TAVILY_SEARCH_CONCURRENCY=4

# local is the safe development default. Cloudinary credentials are secrets from its dashboard.
STORAGE_DRIVER=local
UPLOAD_DIR=./uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
MAX_IMAGE_BYTES=5242880

# Set true only after deploying the registry. Private key must belong to an authorized, testnet-only operator.
ATTESTATION_ENABLED=false
ATTESTATION_NETWORK=ethereum-sepolia
ATTESTATION_CHAIN_ID=11155111
ATTESTATION_RPC_URL=https://rpc.sepolia.org
ATTESTATION_EXPLORER_URL=https://sepolia.etherscan.io
MESH_CONTRACT_ADDRESS=
ATTESTOR_PRIVATE_KEY=
ATTESTATION_CONFIRMATIONS=1

PASSPORT_REUSE_WINDOW_MINUTES=60
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=20
SWAGGER_ENABLED=true
