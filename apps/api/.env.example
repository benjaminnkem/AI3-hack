# ─────────────────────────────────────────────────────────────
# Mesh — copy to .env and fill in. Never commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Backend (apps/api) ──
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://mesh:mesh@localhost:5432/mesh

# Redis (caching)
REDIS_URL=redis://localhost:6379

# ── Gonka Router (REQUIRED for real inference) ──
# Get your key + free hackathon quota at https://gonkarouter.io
GONKA_ROUTER_URL=https://gonkarouter.io
GONKA_API_KEY=
GONKA_TIMEOUT_MS=45000

# ── Blockchain (optional — attestation is skipped if unset) ──
CHAIN_RPC_URL=
CHAIN_PRIVATE_KEY=
CONTRACT_ADDRESS=
CHAIN_ID=

# ── Frontend (apps/web) ──
NEXT_PUBLIC_API_URL=http://localhost:4000
