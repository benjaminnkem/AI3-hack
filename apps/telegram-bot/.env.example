TELEGRAM_BOT_TOKEN=
MESH_API_BASE_URL=http://localhost:4000
MESH_WEB_BASE_URL=http://localhost:3000
MESH_API_PREFIX=api/v1

# Comma-separated chat IDs. Leave empty to allow all chats (demo mode).
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_RATE_LIMIT_SECONDS=90
MESH_REQUEST_TIMEOUT_MS=180000

# polling (local default) | webhook (Render Web Service)
# If unset: webhook when TELEGRAM_WEBHOOK_URL or RENDER_EXTERNAL_URL is present.
TELEGRAM_MODE=
PORT=8080
# Full public origin for webhooks, e.g. https://mesh-telegram-bot.onrender.com
# On Render Web Services, RENDER_EXTERNAL_URL is injected automatically.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook
# Optional shared secret for Telegram webhook header validation
TELEGRAM_WEBHOOK_SECRET=
