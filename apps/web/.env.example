# Public frontend configuration only. Copy to apps/web/.env.local.
# Never place Gonka, Tavily, database, RPC signer, or private-key secrets here.

# Required: public base URL of the Mesh backend API.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Required in production for canonical metadata and social sharing URLs.
# Use the deployed frontend origin, without a trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000
