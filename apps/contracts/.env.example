# Public Ethereum Sepolia RPC; replace with a provider URL for reliable deployment. Not secret.
ETHEREUM_SEPOLIA_RPC_URL=https://rpc.sepolia.org
# Required secret: dedicated testnet wallet private key, funded with Ethereum Sepolia ETH.
DEPLOYER_PRIVATE_KEY=
# Optional owner/operator addresses; deployer is the safe local owner default.
INITIAL_OWNER_ADDRESS=
INITIAL_OPERATOR_ADDRESS=
# Optional secret from https://etherscan.io/myapikey for source verification.
ETHERSCAN_API_KEY=
# Required by the operator script after deployment. Not secret.
MESH_CONTRACT_ADDRESS=
OPERATOR_ADDRESS=
OPERATOR_ALLOWED=true
